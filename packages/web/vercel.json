{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npm install && npm run build -w @asakai/web",
  "installCommand": "cd ../.. && npm install",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3.2.0",
      "maxDuration": 30
    }
  }
}
