{
  "name": "@asakai/desktop",
  "version": "1.0.0",
  "description": "朝会ジェネレーター - Morning Meeting Generator Desktop App",
  "author": "toukanno",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:msix": "tsc && vite build && electron-builder --win appx",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "vite build && electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@asakai/shared": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.toukanno.asakai",
    "productName": "朝会ジェネレーター",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis",
        "appx"
      ]
    },
    "appx": {
      "identityName": "toukanno.AsakaiGenerator",
      "applicationId": "AsakaiGenerator",
      "publisher": "CN=toukanno",
      "publisherDisplayName": "toukanno",
      "displayName": "朝会ジェネレーター",
      "languages": [
        "ja-JP",
        "en-US"
      ],
      "showNameOnTiles": true
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
